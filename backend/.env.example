# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agent_builder

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# Google OAuth: create a Web OAuth Client ID at https://console.cloud.google.com/apis/credentials
# Add both http://localhost:5173 to "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173

# --- LLM ---
GROQ_API_KEY=your_groq_api_key_here

# --- Optional tool keys ---
CRICAPI_KEY=your_free_key_here
